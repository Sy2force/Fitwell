{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
        },
        {
            "src": "backend/build_files.sh",
            "use": "@vercel/static-build",
            "config": { "distDir": "backend/staticfiles" }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/backend/staticfiles/$1"
        },
        {
            "src": "/(.*)",
            "dest": "index.py"
        }
    ]
}
