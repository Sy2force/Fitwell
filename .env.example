# =============================================================================
# FITWELL - CONFIGURATION ENVIRONNEMENT
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs appropriées

# -----------------------------------------------------------------------------
# DJANGO CORE
# -----------------------------------------------------------------------------
# Clé secrète Django (générez-en une unique pour la production)
# Générer avec: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION

# Mode debug (True pour développement, False pour production)
DEBUG=True

# Hosts autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,.onrender.com

# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
# URL de connexion PostgreSQL (optionnel, SQLite par défaut en dev)
# Format: postgres://user:password@host:port/database
# DATABASE_URL=postgres://user:password@localhost:5432/fitwell

# -----------------------------------------------------------------------------
# SÉCURITÉ & CORS
# -----------------------------------------------------------------------------
# Origines CSRF de confiance (séparées par des virgules)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://*.vercel.app,https://*.onrender.com

# Autoriser toutes les origines CORS (True en dev, False en prod)
CORS_ALLOW_ALL_ORIGINS=True

# -----------------------------------------------------------------------------
# EMAIL (Optionnel - pour reset password)
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=FitWell <noreply@fitwell.com>

# -----------------------------------------------------------------------------
# STOCKAGE FICHIERS (Optionnel - pour production)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=fitwell-media
# AWS_S3_REGION_NAME=eu-west-1

# -----------------------------------------------------------------------------
# AUTRES
# -----------------------------------------------------------------------------
# Langue par défaut
# LANGUAGE_CODE=fr

# Fuseau horaire
# TIME_ZONE=Europe/Paris
